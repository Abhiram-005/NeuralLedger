{
  "name": "aichain-contracts",
  "version": "1.0.0",
  "description": "AIChain Solidity smart contracts",
  "scripts": {
    "compile":  "hardhat compile",
    "node":     "hardhat node",
    "deploy":   "hardhat run scripts/deploy.js --network localhost",
    "test":     "hardhat test",
    "start":    "concurrently \"npm run node\" \"sleep 3 && npm run deploy\""
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.0"
  }
}
